<%- include("../partials/nav.ejs") %>

<main class="page-container">
    <h1>View All Listings</h1>

    <% if (allListings.length === 0) { %>
        <p>No listings yet.</p>
    <% } %>

    <ul>
        <% allListings.forEach((item) => { %>
            <li>
                <% if (item.image) { %>
                    <img src="<%= item.image %>" alt="<%= item.service %>" width="200">
                <% } %>

                <h2><%= item.service %></h2>
                <p>Location: <%= item.location %></p>
                <p>Price: $<%= item.price %></p>
                <p>Owned by: <%= item.owner.username %></p>
                <p>Posted: <%= item.createdAt.toLocaleDateString() %></p>
                <a href="/listings/<%= item._id %>/edit">Edit</a>
            </li>
        <% }) %>
    </ul>
</main>
</body>
</html>
