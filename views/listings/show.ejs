<%- include("../partials/nav.ejs") %>

<main class="page-container">
    <% if (listing.image) { %>
        <img src="<%= listing.image %>" alt="<%= listing.service %>" width="300">
    <% } %>

    <h1><%= listing.service %></h1>
    <p>Location: <%= listing.location %></p>
    <p>Price: $<%= listing.price %></p>
    <p>Owned by: <%= listing.owner.username %></p>
    <p>Posted: <%= listing.createdAt.toLocaleDateString() %></p>

    <a class="button-link" href="/listings/<%= listing._id %>/edit">Edit</a>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <button type="submit">Delete</button>
    </form>

    <section class="auth-card">
        <div class="auth-card-header">
            <h2 class="auth-card-title">Reviews</h2>
            <p class="auth-card-subtitle">
                Share your experience with this listing.
            </p>
        </div>

        <form
            class="auth-form"
            action="/listings/<%= listing._id %>/reviews"
            method="POST"
        >
            <div class="form-group">
                <label class="form-label" for="text">Write a Review</label>
                <textarea
                    class="form-input"
                    name="text"
                    id="text"
                    rows="4"
                    required = true
                ></textarea>
            </div>

            <button class="primary-button" type="submit">Post Review</button>
        </form>

        <% if (reviews.length === 0) { %>
            <p>No reviews yet.</p>
        <% } else { %>
            <% reviews.forEach((review) => { %>
                <article class="form-group">
                    <p><strong><%= review.author.username %></strong></p>
                    <p><%= review.text %></p>
                </article>
            <% }) %>
        <% } %>
    </section>
</main>
</body>
</html>
